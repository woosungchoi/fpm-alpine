#!/bin/bash
set -e

echo "=> Building multi-arch (amd64 & arm64) for branch: $SOURCE_BRANCH"

if docker buildx inspect mybuilder >/dev/null 2>&1; then
  docker buildx use mybuilder
else
  docker buildx create --name mybuilder --use
fi

# Modern BuildKit environments usually provide cross-platform support already.
# Avoid forcing a legacy qemu-user-static registration step here: it can fail with
# "exec /register: exec format error" on arm64 hosts and Docker Hub builders.

# Build both architectures and publish a single multi-arch tag.
docker buildx build --platform linux/amd64,linux/arm64 -f "$DOCKERFILE_PATH" -t "$IMAGE_NAME" --push .
